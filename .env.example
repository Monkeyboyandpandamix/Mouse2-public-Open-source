# M.O.U.S.E. Ground Control Station - Environment Variables
# Copy this file to .env and customize as needed

# ===========================================
# CORE SETTINGS
# ===========================================

# Server port (default: 5000)
PORT=5000

# Environment mode: development or production
NODE_ENV=production

# Data directory for local JSON storage (default: ./data)
DATA_DIR=./data

# Device role: Leave empty for ground control, set to ONBOARD for Raspberry Pi mode
# DEVICE_ROLE=ONBOARD

# ===========================================
# GOOGLE INTEGRATION (Optional)
# ===========================================
# Required for Google Drive/Sheets backup functionality
# Get credentials from Google Cloud Console: https://console.cloud.google.com

# OAuth Client ID and Secret
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# OAuth redirect URI (update for your domain if deploying remotely)
GOOGLE_REDIRECT_URI=http://localhost:5000/api/google/oauth/callback

# Google Sheets ID for data backup (create a new sheet and copy the ID from URL)
# GOOGLE_SHEET_ID=your-sheet-id

# Google Drive folder ID for media backup
# GOOGLE_DRIVE_FOLDER_ID=your-folder-id

# ===========================================
# SECURITY SETTINGS
# ===========================================

# Session secret for Express sessions (generate a random 32+ character string)
# IMPORTANT: Set this to a secure random value in production!
SESSION_SECRET=change-this-to-a-random-string-in-production

# Encryption key for Google tokens (generate a random 32+ character string)
# If not set, falls back to SESSION_SECRET
GOOGLE_AUTH_ENCRYPTION_KEY=change-this-to-another-random-string

# ===========================================
# OPTIONAL SETTINGS
# ===========================================

# External restricted-airspace provider (OpenAIP)
# Used by /api/airspace/restricted for live no-fly overlays and route avoidance.
# Get a key from OpenAIP and set it here.
# OPENAIP_API_KEY=your-openaip-api-key
# OPENAIP_BASE_URL=https://api.core.openaip.net/api
# Comma-separated authorization codes allowed to override restricted airspace routing
# AIRSPACE_AUTH_CODES=AUTH-CODE-1,AUTH-CODE-2

# Python path for MAVLink scripts (default: /usr/bin/python3)
# On Raspberry Pi with venv, use full path to system Python for hardware access:
# PYTHON_PATH=/usr/bin/python3
#
# Disable auto-opening browser on startup (set to 1 to disable)
# NO_BROWSER=1

# Enable debug logging
# DEBUG=true

# Custom base URL for the application (if behind a reverse proxy)
# BASE_URL=https://your-domain.com
